#!/usr/bin/env sh
#
# Pre-commit gate: refuse the commit if quality checks fail in shipped source.
# Covers React frontend (eslint/prettier/tsc/react-doctor) + PHP/Laravel (pint/phpstan)
# + impeccable UI anti-pattern detection.
#
# Each check exits non-zero to block the commit. Bypass only in a genuine
# emergency with:  git commit --no-verify
#
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

run_or_skip () {
  # $1 = human label, rest = command. Skips gracefully if toolchain missing.
  label="$1"; shift
  echo "→ $label ..."
  if "$@"; then
    echo "  ✓ $label passed."
  else
    echo "  ✗ $label FAILED — commit blocked. Fix above, or: git commit --no-verify"
    exit 1
  fi
}

# --- Frontend (React / Inertia) ---
if [ -d node_modules ]; then
  run_or_skip "ESLint"           npm run lint:check
  run_or_skip "Prettier"         npm run format:check
  run_or_skip "TypeScript"       npm run types:check
  # react-doctor optional until installed; warn but don't block if missing.
  if [ -x node_modules/.bin/react-doctor ] || command -v npx >/dev/null 2>&1; then
    echo "→ react-doctor ..."
    if npx react-doctor@latest --no-telemetry; then
      echo "  ✓ react-doctor passed."
    else
      echo "  ✗ react-doctor FAILED — commit blocked. Run 'npx react-doctor@latest' to inspect."
      exit 1
    fi
  else
    echo "→ react-doctor: skipped (npx unavailable)."
  fi
else
  echo "→ Frontend checks skipped (no node_modules); run 'npm install' first."
fi

# --- Backend (PHP / Laravel) ---
if [ -d vendor ]; then
  run_or_skip "Pint"     vendor/bin/pint --test --format agent
  run_or_skip "PHPStan"  vendor/bin/phpstan analyse --no-progress
else
  echo "→ PHP checks skipped (no vendor); run 'composer install' first."
fi

# --- UI anti-pattern detection (impeccable) ---
if command -v bunx >/dev/null 2>&1; then
  run_or_skip "impeccable" bunx impeccable detect resources/ --quiet
else
  echo "→ impeccable skipped (bunx unavailable)."
fi

echo "✓ Pre-commit gate passed."
